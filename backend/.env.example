# ── API key (optional for the demo) ──
# Bundled example graphs load with NO key. A key is only needed to process an
# uploaded PDF — either set one here so the server does it for everyone, or
# leave it blank and let visitors bring their own key in the UI.
# DeepSeek (or any OpenAI-compatible provider). Free tier works.
DEEPSEEK_API_KEY=

# Point at a different OpenAI-compatible endpoint if not using DeepSeek.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── CORS ──
# Comma-separated list of frontend origins allowed by CORS. In production set
# this to your Vercel domain so the deployed frontend can reach the backend.
CORS_ORIGINS=http://localhost:3000
# e.g. CORS_ORIGINS=https://knowledge-mapper.vercel.app

# Maximum upload size in megabytes.
MAX_UPLOAD_SIZE_MB=50

# ── Persistence (optional) ──
# Bundled examples are re-seeded on every boot, so they survive Railway's
# ephemeral disk regardless. To persist user-uploaded graphs across restarts,
# mount a Railway volume and point these at it.
# DB_PATH=/data/knowledge.db
# UPLOAD_DIR=/data/uploads

# Further pipeline tuning knobs (page/chunk/concept/relationship caps) live in
# app/config.py and can each be overridden by an environment variable of the
# same name — see that file for the full list and defaults.
