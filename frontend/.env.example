# Knowledge Mapper frontend (Next.js) configuration.
#
# Local dev defaults to the backend on http://localhost:8000 — no setup needed.
#
# For production (Vercel), set this to your Railway backend's public URL so the
# frontend calls it directly. The backend's CORS_ORIGINS must then include the
# Vercel domain (see backend env). NEXT_PUBLIC_* vars are baked in at build time.
#
# NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app
