# ── Required ──
# DeepSeek API key (or any OpenAI-compatible provider). Free tier works.
DEEPSEEK_API_KEY=sk-your-key-here

# ── Optional ──
# Point at a different OpenAI-compatible endpoint if not using DeepSeek.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Comma-separated list of frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000

# Maximum upload size in megabytes.
MAX_UPLOAD_SIZE_MB=50

# Further pipeline tuning knobs (page/chunk/concept/relationship caps) live in
# app/config.py and can each be overridden by an environment variable of the
# same name — see that file for the full list and defaults.
